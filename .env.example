# ─────────────────────────────────────────────────────────────
# PRASAD ERP — environment config (copy to .env and fill in)
# ─────────────────────────────────────────────────────────────

# Google (the ONLY allowed external APIs in this project)
VITE_GOOGLE_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# 🤖 LOCAL LLM (Ollama + Gemma 4) — default engine, 100% local & free.
# Swap the model variant by editing VITE_LLM_MODEL only (no code changes).
VITE_LLM_PROVIDER=ollama
VITE_LLM_BASE_URL=http://localhost:11434
VITE_LLM_MODEL=gemma4:12b
VITE_LLM_FALLBACK_MODEL=gemma4:e4b
VITE_LLM_TEMPERATURE=0.4
VITE_LLM_TIMEOUT_MS=120000
VITE_LLM_EMBED_MODEL=nomic-embed-text

# ☁️ CLOUD AI (optional) — Bill Scanner ka "Cloud AI (Claude Haiku)" engine.
# Key SIRF bridge server (bridge.cjs) padhta hai — kabhi VITE_ prefix mat lagana,
# warna key browser bundle me chali jayegi!
ANTHROPIC_API_KEY=sk-ant-your-key-here
# claude-3-haiku-20240307 RETIRED ho chuka hai (Apr 2026) — current Haiku:
ANTHROPIC_MODEL=claude-haiku-4-5
# Ollama URL as seen FROM the bridge (local proxy mode ke liye)
OLLAMA_BASE_URL=http://localhost:11434

# Frontend -> bridge server URL (cloud AI + uploads isi se hokar jaate hain).
# LOCAL dev: http://localhost:3000. PRODUCTION (live site): apne Cloudflare
# Tunnel ka HTTPS URL daalein, e.g. https://ollama.prasadtransport.com
VITE_BRIDGE_URL=http://localhost:3000

# 🌐 SECURE TUNNEL — live HTTPS site apne PC ke Ollama tak isi se pahunchti hai.
# Poori setup ke liye: CLOUDFLARE-TUNNEL-SETUP.md
#
# (a) BRIDGE SIDE — accepted client secrets (comma-separated = multi-app).
#     Har app ka apna token; kisi ek ko rotate/revoke karna ho to baaki safe.
#     Strong random banayein:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#     UNSET chhodne par gate OFF ho jata hai (sirf local-only dev ke liye).
PT_BRIDGE_TOKEN=prasad-transport-token-here,jaiswal-capital-token-here
#
# (b) BROWSER APPS jinhe allow karna hai (comma-separated). Server-to-server
#     callers (jaise Jaiswal Capital ka AWS backend) ko yahan add karne ki
#     zaroorat NAHI — unke paas Origin header hi nahi hota, sirf token chahiye.
ALLOWED_ORIGINS=https://www.prasadtransport.com,https://prasadtransport.com,https://app.jaiswalcapital.com,http://localhost:5173,http://localhost:4173,capacitor://localhost,http://localhost
#
# (c) FRONTEND SIDE — is app ka apna token (bridge ke PT_BRIDGE_TOKEN list me se
#     ek). Live build me hi set karein; local dev me khaali chalta hai.
#     ⚠️ Yeh browser bundle me embed hota hai — bots/random traffic rokta hai,
#     par asli secret vault nahi. Sabse strong gate = Cloudflare Access (doc).
VITE_LLM_AUTH_TOKEN=prasad-transport-token-here
#
# (d) LIVE SITE ke liye local engine ko tunnel URL par point karein (dev me
#     localhost:11434 rehne dein):
# VITE_LLM_BASE_URL=https://ollama.prasadtransport.com

# 📧 EMAIL BILL PARSER (email-parser.cjs) — email accounts .env me NAHI rehte;
# wo ERP ke "Email Bill Parser" screen (EMAIL_ACCOUNTS collection) me manage
# hote hain. Parser ANTHROPIC_API_KEY (upar) use karta hai. Chalane ke liye:
#   node email-parser.cjs          (scheduler — poll interval UI se set hota hai)
#   node email-parser.cjs --once   (single pass, cron/Task Scheduler ke liye)
